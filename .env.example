# Configuración de Supabase (backend)
SUPABASE_URL=https://rzuyndmogkawqdstlnht.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# JWT secret del proyecto Supabase (Dashboard > Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Configuración de Supabase (frontend - prefijo VITE_ para que Vite las exponga)
VITE_SUPABASE_URL=https://rzuyndmogkawqdstlnht.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Configuración de N8N
N8N_WEBHOOK_URL=your_n8n_webhook_url_here
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret_here

# CORS: orígenes permitidos (separados por coma)
# En desarrollo no hace falta, usa localhost por defecto
# ALLOWED_ORIGINS=https://tudominio.com

# Logging
# Nivel: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Nombre del fichero de log (relativo a backend/log/)
LOG_FILENAME=modeloshaciendaweb.log

# API key para el agente email-contact-helper (header X-API-Key)
EMAIL_CONTACT_HELPER_API_KEY=your_secret_key_here
